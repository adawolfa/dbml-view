{
  "name": "dbml-view",
  "version": "0.0.0",
  "private": true,
  "description": "Read-only DBML viewer — diagram + structure",
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@11.1.3",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm --filter @dbml-view/web dev",
    "typecheck": "pnpm -r typecheck",
    "lint": "biome check .",
    "format": "biome format --write .",
    "test:e2e": "pnpm --filter @dbml-view/web e2e"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "typescript": "^6.0.3"
  }
}
