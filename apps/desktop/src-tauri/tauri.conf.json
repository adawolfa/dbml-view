{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "DBMLView",
  "version": "0.0.0",
  "identifier": "cz.klva.dbml-view",
  "build": {
    "beforeBuildCommand": "pnpm --filter @dbml-view/web build",
    "frontendDist": "../../web/dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "DBML View",
        "width": 1280,
        "height": 800,
        "minWidth": 480,
        "minHeight": 320,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "fileAssociations": [
      {
        "ext": ["dbml"],
        "name": "DBML schema",
        "description": "Database Markup Language file",
        "role": "Viewer"
      }
    ]
  }
}
